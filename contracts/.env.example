# ==========================================================
# DoeFacil / contracts (Hardhat) — modelo de variaveis
# Copie este arquivo para ".env" e preencha. NUNCA comite o .env real.
# Em desenvolvimento local nenhuma destas variaveis e obrigatoria.
# ==========================================================

# URL do endpoint da testnet Sepolia (painel do Alchemy ou Infura).
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/SUA_API_KEY"

# Chave privada da conta de deploy. USE UMA CARTEIRA SO DE TESTNET.
# Sem fundos reais. Pode ser com ou sem o prefixo "0x".
PRIVATE_KEY="sua_chave_privada_de_testnet_aqui"

# API key do Etherscan para verificar o contrato (npx hardhat verify).
ETHERSCAN_API_KEY="sua_api_key_do_etherscan"

# Relatorio de gas nos testes (opcional). "true" para ativar.
REPORT_GAS=false
COINMARKETCAP_API_KEY=""
